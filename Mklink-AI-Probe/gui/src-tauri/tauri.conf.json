{
  "productName": "Mklink AI Probe",
  "version": "0.1.0",
  "identifier": "com.microkeen.mklink-ai-probe",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Mklink AI Probe",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "freezePrototype": false,
      "pattern": {
        "use": "brownfield"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "resources": [
      "resources/THIRD-PARTY-NOTICES.txt"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://gitee.com/Aladdin-Wang/Mklink-AI-Probe/raw/updates/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDUxOEE2QkM3REYyQjA3OTkKUldTWkJ5dmZ4MnVLVWRVKzV0WmRLQWg3VDc2Ky9td2tZZWJheW1lTzNzNEErbmQ3T2JteE1jUTMK"
    }
  }
}
